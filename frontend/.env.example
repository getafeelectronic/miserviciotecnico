# Variables de entorno para desarrollo local
# Copia este archivo como .env y completa con tus valores reales

# EmailJS Configuration
# Obtén tus credenciales en https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=tu_service_id_aqui
VITE_EMAILJS_TEMPLATE_ID=tu_template_id_aqui
VITE_EMAILJS_PUBLIC_KEY=tu_public_key_aqui

# Google Maps API
# Crea tu proyecto y API key en https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# Información del Negocio
VITE_BUSINESS_EMAIL=contacto@telerayo.com
VITE_BUSINESS_PHONE=+34 123 456 789
VITE_BUSINESS_ADDRESS=Calle Example, 123, Getafe, Madrid
VITE_BUSINESS_HOURS=Lun-Vie: 9:00 - 19:00

# Coordenadas para Google Maps (Getafe, Madrid)
VITE_BUSINESS_COORDINATES_LAT=40.3063
VITE_BUSINESS_COORDINATES_LNG=-3.7322
